# ── Serveur ───────────────────────────────────────────────
PORT=6001
NODE_ENV=production

# ── Laravel (vérification token + lecture conversation) ────
LARAVEL_INTERNAL_URL=https://careasy.cap-epac.bj
# Secret partagé pour sécuriser les appels Node → Laravel (header X-Internal-Secret)
INTERNAL_API_SECRET=CHANGE_ME_random_64_chars

# ── Redis (scalabilité horizontale multi-instances) ─────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── MySQL (lecture directe — membership conversation, présence) ─
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=careasy
DB_USER=careasy_user
DB_PASSWORD=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=https://careasy.cap-epac.bj,https://careasy26.vercel.app
